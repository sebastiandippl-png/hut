APP_ENV=development

# Database — set APP_ENV=production + DB_HOST etc. for MariaDB
DB_DSN=sqlite:/var/www/hut/storage/hut.sqlite
DB_USERNAME=
DB_PASSWORD=

# MariaDB (production)
DB_DSN=mysql:host=localhost;dbname=hut;charset=utf8mb4
DB_USERNAME=hut_user
DB_PASSWORD=secret

# Session
SESSION_NAME=hut_session
SESSION_SECRET=change_me_to_random_string

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
